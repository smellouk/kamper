<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_base">

    <!-- Footer pinned to bottom -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@color/color_mantle">

        <TextView
            android:id="@+id/lowMemBadge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="@color/color_red"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center_vertical"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/allocButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alloc 32 MB"
            android:textColor="@color/color_text"
            app:strokeColor="@color/color_overlay"
            app:backgroundTint="@color/color_surface0"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/gcButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Force GC"
            android:textColor="@color/color_text"
            app:strokeColor="@color/color_overlay"
            app:backgroundTint="@color/color_surface0"/>

    </LinearLayout>

    <!-- Scroll content fills above footer -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/footer"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Heap Memory"
                android:textColor="@color/color_subtext"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <com.smellouk.kamper.android.views.MetricRowView
                android:id="@+id/heapRow"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/heapDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2014;"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:fontFamily="monospace"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System RAM"
                android:textColor="@color/color_subtext"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <com.smellouk.kamper.android.views.MetricRowView
                android:id="@+id/ramRow"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/ramDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2014;"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:fontFamily="monospace"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PSS Breakdown  (Android only)"
                android:textColor="@color/color_subtext"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/pssDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2014;"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
