<?xml version="1.0" encoding="utf-8"?>
<!-- Android TV leanback launcher banner — 320×180dp -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep background -->
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="135"
                      android:startColor="#181825" android:endColor="#1E1E2E"/>
            <size android:width="320dp" android:height="180dp"/>
        </shape>
    </item>

    <!-- Subtle blue glow from top-left -->
    <item android:right="180dp">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="0"
                      android:startColor="#2089B4FA" android:endColor="#00181825"/>
        </shape>
    </item>

    <!-- Left accent bar -->
    <item android:width="6dp" android:gravity="left">
        <shape android:shape="rectangle">
            <solid android:color="#89B4FA"/>
        </shape>
    </item>

    <!-- Left panel: horizontal metric spark-bars -->
    <!-- CPU (blue, 85dp) -->
    <item android:left="18dp" android:right="217dp" android:top="42dp" android:bottom="132dp">
        <shape android:shape="rectangle">
            <solid android:color="#89B4FA"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>
    <!-- FPS (green, 60dp) -->
