# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# react-native-kamper is symlinked into node_modules (package.json file: reference).
# The podspec uses '../xcframework/...' relative to the symlink target; CocoaPods does
# not follow symlinks when resolving vendored_frameworks, so that path would land in
# node_modules/xcframework/ (non-existent). Create a sibling symlink here — at Podfile
# load time, before podspec analysis — so the path resolves correctly.
_nm_dir   = File.expand_path('../node_modules', __dir__)
_xcfw_link = File.join(_nm_dir, 'xcframework')
unless File.exist?(_xcfw_link)
  _xcfw_real = File.expand_path('../../../libs/xcframework', __dir__)
  File.symlink(_xcfw_real, _xcfw_link)
end

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

pre_install do |installer|
  puts "Building Kamper XCFramework (this may take a moment on first run)..."
  repo_root = File.expand_path('../../../', __dir__)
  system("cd '#{repo_root}' && ./gradlew :libs:xcframework:assembleKamperReleaseXCFramework")
end

target 'KamperRn' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Kamper.xcframework is built by a script phase and doesn't exist at pod install
    # time, so CocoaPods omits vendored_frameworks entries. Patch xcconfig files
    # directly so the compiler and linker can find Kamper.framework.
    kamper_fw_dir = File.expand_path('../../../libs/xcframework/build/XCFrameworks/release/Kamper.xcframework/ios-arm64-simulator', installer.config.installation_root)

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        xcconfig_path = bc.base_configuration_reference&.real_path
        next unless xcconfig_path && File.exist?(xcconfig_path)
        content = File.read(xcconfig_path)
        modified = false

        # Add xcframework slice to FRAMEWORK_SEARCH_PATHS for compiler header lookup.
        unless content.include?(kamper_fw_dir)
          content.sub!(/^(FRAMEWORK_SEARCH_PATHS = .*)$/, "\\1 \"#{kamper_fw_dir}\"")
          modified = true
        end

        # Add -framework Kamper to OTHER_LDFLAGS for the app-aggregate xcconfig so
        # the linker resolves symbols from libreact-native-kamper.a.
        if target.name == 'Pods-KamperRn' && !content.include?('-framework "Kamper"')
          content.sub!(/^(OTHER_LDFLAGS = .*)$/, "\\1 -framework \"Kamper\"")
          modified = true
        end

        File.write(xcconfig_path, content) if modified
      end
    end
  end
end
