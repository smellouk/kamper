{
  "name": "react-native-konitor",
  "version": "0.1.0",
  "description": "Konitor performance monitoring for React Native — TurboModule library exposing CPU, FPS, memory, network, and overlay UI",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": ["src/", "android/", "ios/", "react-native-konitor.podspec", "package.json", "README.md"],
  "android": "./android",
  "ios": "./ios/KonitorTurboModule.h",
  "scripts": {
    "test": "jest --no-coverage",
    "tsc": "tsc --noEmit"
  },
  "keywords": ["react-native", "performance", "monitoring", "konitor", "turbomodule"],
  "author": "smellouk <sidali.mellouk@zattoo.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/smellouk/konitor",
  "codegenConfig": {
    "name": "NativeKonitorModuleSpec",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.smellouk.konitor.rn"
    },
    "ios": {
      "modulesProvider": {
        "KonitorModule": "KonitorTurboModule"
      }
    }
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.73.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "jest": "^29.6.3",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "typescript": "^5.8.3"
  }
}
