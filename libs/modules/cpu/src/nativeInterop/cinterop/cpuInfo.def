language = C
headers = mach/mach.h sys/sysctl.h

---

typedef struct {
    long user;
    long sys;
    long idle;
    long nice;
    int valid; /* 0 = ok, -1 = error */
} KonitorCpuTicks;

/* Fill *out with CPU tick counters from Mach host_statistics.
 * Returns 0 on success, -1 on failure.
 * Avoids popen("top") overhead — kernel counter read, returns immediately. */
static int konitor_fill_cpu_ticks(KonitorCpuTicks *out) {
    host_cpu_load_info_data_t info;
    mach_msg_type_number_t count = HOST_CPU_LOAD_INFO_COUNT;
    if (host_statistics(mach_host_self(), HOST_CPU_LOAD_INFO,
                        (host_info_t)&info, &count) != KERN_SUCCESS) {
        out->valid = -1;
        return -1;
    }
    out->user  = (long)info.cpu_ticks[CPU_STATE_USER];
    out->sys   = (long)info.cpu_ticks[CPU_STATE_SYSTEM];
    out->idle  = (long)info.cpu_ticks[CPU_STATE_IDLE];
    out->nice  = (long)info.cpu_ticks[CPU_STATE_NICE];
    out->valid = 0;
    return 0;
}

/* Number of logical CPU cores. Used to normalize multi-threaded app CPU %. */
static int konitor_get_logical_cpu_count(void) {
    int count = 0;
    size_t len = sizeof(count);
    sysctlbyname("hw.logicalcpu", &count, &len, NULL, 0);
    return count > 0 ? count : 1;
}
